SlateportCity_House_Text_NatureToDoWithStatGains:
# 14 "data/maps/SlateportCity_House/scripts.pory"
	.string "They say Slateport grew from nothing\n"
# 15 "data/maps/SlateportCity_House/scripts.pory"
	.string "but clean water and abundant food.\p"
# 16 "data/maps/SlateportCity_House/scripts.pory"
	.string "Now ships and people from all\n"
# 17 "data/maps/SlateportCity_House/scripts.pory"
	.string "over Hoenn come here to trade.\p"
# 18 "data/maps/SlateportCity_House/scripts.pory"
	.string "Some nights, fishermen swear they\n"
# 19 "data/maps/SlateportCity_House/scripts.pory"
	.string "heard whispers carried by the tide.\p"
# 20 "data/maps/SlateportCity_House/scripts.pory"
	.string "Ancient tales speak of deep currents\n"
# 21 "data/maps/SlateportCity_House/scripts.pory"
	.string "that hide secrets beneath the waves…$"
# 22 "data/maps/SlateportCity_House/scripts.pory"

# 23 "data/maps/SlateportCity_House/scripts.pory"
SlateportCity_House_Text_MustBeGoingToBattleTent:
# 24 "data/maps/SlateportCity_House/scripts.pory"
	.string "Welcome to Slateport City.\n"
# 25 "data/maps/SlateportCity_House/scripts.pory"
	.string "This place is where people and\l"
# 26 "data/maps/SlateportCity_House/scripts.pory"
	.string "POKéMON cross paths with nature.\p"
# 27 "data/maps/SlateportCity_House/scripts.pory"
	.string "A market grew from clean water,\n"
# 28 "data/maps/SlateportCity_House/scripts.pory"
	.string "and a lighthouse guards the bay.\p"
# 29 "data/maps/SlateportCity_House/scripts.pory"
	.string "Some sailors swear the ocean here\n"
# 30 "data/maps/SlateportCity_House/scripts.pory"
	.string "holds echoes of things long lost…$"
